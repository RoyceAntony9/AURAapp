# AURA Environment Configuration

# Database & Cache Connection
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aura_db
REDIS_URL=redis://localhost:6379/0

# Mode configuration
# Set MOCK_MODE to true to bypass all external APIs (OpenAI, Reddit, Trends, News)
# This allows running the MVP with zero configuration / API keys.
MOCK_MODE=true

# External APIs (Required only if MOCK_MODE=false)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
NEWS_API_KEY=your_news_api_key_here
